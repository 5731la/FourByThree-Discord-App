# Environment variables for the FourByThree Discord Activity server.
# Copy this file to .env and fill in your values.

# Your Discord Application's Client ID (from https://discord.com/developers/applications)
export DISCORD_CLIENT_ID=your_client_id_here

# Port the Go server listens on (default: 3000)
export PORT=4343

export DISCORD_PUBLIC_KEY=pubkey
export DISCORD_CLIENT_SECRET=foroauth
# Only needed for the one-time slash command registration curl, not for running the proxy:
export DISCORD_BOT_TOKEN=